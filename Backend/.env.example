# ─────────────────────────────────────────────────────────────────────────────
# Trip Smart backend — copy this file to `.env` and fill in the values below.
# The tables (districts, weather_observations, forecast_runs) are created
# AUTOMATICALLY in Supabase the first time the server starts. You never run
# SQL by hand.
# ─────────────────────────────────────────────────────────────────────────────

PROJECT_NAME="Trip Smart"
ENVIRONMENT=development

# ─── REQUIRED: the database connection ───────────────────────────────────────
# Where to find it in Supabase:
#   1. Open your project at https://supabase.com/dashboard
#   2. Click the "Connect" button at the top of the page
#   3. Under "Connection String", pick the **Session pooler** tab
#      (use Session pooler, NOT "Direct connection" — direct is IPv6-only
#       and usually fails on home networks)
#   4. Copy the URI. It looks like:
#      postgresql://postgres.abcdefghij:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
#   5. Replace [YOUR-PASSWORD] with your database password
#      (the one you chose when creating the project; reset it under
#       Project Settings → Database if you forgot it)
# NOTE: if your password contains special characters (@ : / # ?), percent-encode
# them in the URL — e.g. "@" becomes "%40".
SUPABASE_DB_URL=

# ─── OPTIONAL: Supabase API credentials (not used yet) ───────────────────────
# Only needed later for Supabase Auth / storage features, NOT for forecasting.
# Found under: Project Settings → API
#   SUPABASE_URL  = the "Project URL"          (https://<your-ref>.supabase.co)
#   SUPABASE_KEY  = the "anon / public" API key (a long JWT starting with eyJ...)
SUPABASE_URL=
SUPABASE_KEY=

# ─── Security ────────────────────────────────────────────────────────────────
# Any long random string; used to sign this API's own JWTs.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── Forecast behaviour ──────────────────────────────────────────────────────
# Reuse a completed model run for this many minutes before re-running the GRU.
FORECAST_CACHE_MINUTES=60
