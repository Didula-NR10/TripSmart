# Copy to .env and fill in. Expo CLI loads .env automatically.

# Where the FastAPI backend runs (uvicorn main:app --host 0.0.0.0 --port 8000).
# Testing in a web browser: http://localhost:8000 works.
# Testing on a PHONE (Expo Go): use your PC's LAN IP instead, e.g.
# http://192.168.1.5:8000 — "localhost" on the phone means the phone itself.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Only needed for standalone Android builds (npx expo run:android / EAS).
# Expo Go uses Expo's own key, so leave blank during development.
# Get one at https://console.cloud.google.com — enable "Maps SDK for Android",
# then restrict the key to package name + SHA-1 fingerprint.
GOOGLE_MAPS_ANDROID_API_KEY=
